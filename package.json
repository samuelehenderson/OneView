{
  "name": "ghostmap",
  "private": true,
  "version": "0.3.0",
  "type": "module",
  "description": "GhostMap — reverse-engineer a building from its control program (Siemens PPCL static analysis)",
  "scripts": {
    "dev": "tsx watch server/src/index.ts --port 8787",
    "server": "tsx watch server/src/index.ts --port 8787",
    "start": "tsx server/src/index.ts",
    "build": "echo \"GhostMap is a static app served by the API server — no build step\"",
    "typecheck": "tsc -p tsconfig.server.json"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "express": "^4.21.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "pg": "^8.22.0",
    "tsx": "^4.19.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.7.4",
    "@types/pg": "^8.20.0",
    "typescript": "^5.6.2"
  },
  "engines": {
    "node": ">=20"
  }
}
